# ── Supabase ──────────────────────────────────────────────────
# Project URL from: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service role key (has full DB access — never expose publicly)
# Found at: Supabase dashboard → Settings → API → service_role
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Voyage AI ─────────────────────────────────────────────────
# Get at: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=your-voyage-api-key

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# The public-facing base URL of this API (used in agent.json and MCP responses)
API_BASE_URL=https://api.scory.com

# The public-facing URL of the directory (used in agent.json)
SITE_URL=https://scory.com

# ── Rate Limiting ─────────────────────────────────────────────
# Max requests per IP per 15-minute window (free agent access)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Monitoring Cron ───────────────────────────────────────────
# How often to ping each listing (cron expression)
# Default: every hour
MONITOR_CRON_SCHEDULE=0 * * * *

# Timeout for each endpoint ping in milliseconds
MONITOR_PING_TIMEOUT_MS=8000
